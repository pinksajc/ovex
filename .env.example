# ============================================================
# Orvex — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase (public — safe for browser) ─────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase (private — server only) ─────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=

# ── Attio CRM ─────────────────────────────────────────────────
ATTIO_API_KEY=

# ── DocuSeal (e-signature) ────────────────────────────────────
DOCUSEAL_API_KEY=
# Webhook secret — set in DocuSeal dashboard → Webhooks → Signing secret
DOCUSEAL_WEBHOOK_SECRET=

# ── PDF generation ────────────────────────────────────────────
# Local dev only: path to your local Chrome/Chromium binary.
# On Vercel this variable should be left unset — @sparticuz/chromium
# is used automatically.
# Example (macOS): /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CHROME_EXECUTABLE_PATH=
